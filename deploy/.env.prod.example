# Copy to deploy/.env.prod on the server and fill in. Do NOT commit the real file.
STACK=rubric_prod
NEXTAUTH_URL=https://rubric.maahirahmed.com
AUTH_SECRET=          # generate: openssl rand -base64 32
DB_PASSWORD=          # generate: openssl rand -base64 24
SOCIETY_SLUG=         # e.g. secsoc — leave blank for multi-society mode
APP_NAME=Rubric Portal

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@maahirahmed.com
