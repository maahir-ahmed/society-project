generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  EXECUTIVE
  DIRECTOR
  SUBCOMMITTEE
}

enum ContentRequestStatus {
  DRAFT
  SUBMITTED
  ASSIGNED
  IN_PROGRESS
  AWAITING_INFORMATION
  COMPLETED
  CANCELLED
}

// Arc activity grant lifecycle for an event (tracked per content request).
enum ActivityGrantStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum RoomBookingStatus {
  SUBMITTED
  UNDER_REVIEW
  WAITING_ON_INFORMATION
  SUBMITTED_TO_ARC
  APPROVED
  REJECTED
  COMPLETED
}

enum TreasuryStatus {
  DRAFT
  AWAITING_APPROVAL
  REJECTED
  REIMBURSEMENT_PENDING
  REIMBURSED
}

enum PreferredLocation {
  LECTURE_THEATRE
  CATS_ROOM
  SECLAB
  ROUNDHOUSE
  OUTDOOR_SPACE
  OTHER
}

// Flow: PENDING_APPROVAL -> (exec approves) PENDING_ARC_SUBMISSION -> (submitted
// on the Arc web portal) SUBMITTED -> READY_FOR_PICKUP. Rejection is terminal.
enum PrintingStatus {
  PENDING_APPROVAL
  PENDING_ARC_SUBMISSION
  SUBMITTED
  READY_FOR_PICKUP
  REJECTED
}

enum SecretarialTier {
  BRONZE
  SILVER
  GOLD
}

enum NotificationType {
  ASSIGNMENT
  APPROVAL_REQUIRED
  STATUS_CHANGE
  COMMENT
  MENTION
  DEADLINE_REMINDER
  EXECUTIVE_ACTION_REQUIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  ASSIGN
  STATUS_CHANGE
  COMMENT
  LOGIN
  LOGOUT
}

// ─── Core entities ─────────────────────────────────────────────────────────────

model Society {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  bannerUrl      String?
  primaryColor   String   @default("#0052CC")
  secondaryColor String   @default("#00B8D9")
  contactEmail         String?
  website              String?
  facebookUrl          String?
  instagramUrl         String?
  discordUrl           String?
  linkedinUrl          String?
  description          String?
  rubricSessionId      String?
  rubricSocietyId      String?
  rubricUnionSessionId String?
  secretarialTier      SecretarialTier @default(BRONZE)
  createdAt            DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships      SocietyMembership[]
  departments      Department[]
  titles           SocietyTitle[]
  contentRequests  ContentRequest[]
  roomBookings     RoomBooking[]
  treasuryRequests TreasuryRequest[]
  printingRequests PrintingRequest[]
  announcements    Announcement[]
  auditLogs        AuditLog[]
  budgetCategories BudgetCategory[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String?
  avatarUrl        String?
  phone            String?
  zId              String?
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  memberships       SocietyMembership[]
  accounts          Account[]
  sessions          Session[]
  notifications     Notification[]
  comments          Comment[]
  contentRequests   ContentRequest[]     @relation("ContentRequestSubmitter")
  assignedContent   ContentRequest[]     @relation("ContentRequestAssignee")
  roomBookings      RoomBooking[]        @relation("RoomBookingSubmitter")
  assignedRooms     RoomBooking[]        @relation("RoomBookingAssignee")
  treasuryRequests  TreasuryRequest[]    @relation("TreasurySubmitter")
  treasuryApprovals TreasuryApproval[]
  printingRequests  PrintingRequest[]    @relation("PrintingSubmitter")
  bankAccounts      BankAccount[]
  auditLogs         AuditLog[]
}

model SocietyMembership {
  id           String   @id @default(cuid())
  userId       String
  societyId    String
  role         Role     @default(SUBCOMMITTEE)
  departmentId String?
  title        String?
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  society    Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])

  @@unique([userId, societyId])
  @@index([societyId])
  @@index([userId])
}

model Department {
  id        String   @id @default(cuid())
  societyId String
  name      String
  createdAt DateTime @default(now())

  society     Society             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  memberships SocietyMembership[]
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Content Requests ─────────────────────────────────────────────────────────

model ContentRequest {
  id              String               @id @default(cuid())
  societyId       String
  submittedById   String
  assignedToId    String?
  eventName       String
  startDate       DateTime
  endDate         DateTime?
  location        String
  keyPoints       String               @db.Text
  deadline        DateTime
  bannerRequired  Boolean              @default(false)
  blurbRequired   Boolean              @default(false)
  rubricRequired  Boolean              @default(false)
  otherNotes      String?              @db.Text
  status          ContentRequestStatus @default(DRAFT)
  rubricEventLink String?
  rubricQrCodeUrl String?
  rubricEventId   String?
  rubricSubmittedAt DateTime?
  activityGrantStatus ActivityGrantStatus @default(NOT_SUBMITTED)
  finishedBlurb   String?              @db.Text   // marketing pastes the final event blurb here
  bannerDone      Boolean              @default(false)
  blurbDone       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  society      Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  submittedBy  User    @relation("ContentRequestSubmitter", fields: [submittedById], references: [id])
  assignedTo   User?   @relation("ContentRequestAssignee", fields: [assignedToId], references: [id])
  thread       Thread?
  deliverables ContentDeliverable[]

  @@index([societyId])
  @@index([status])
}

// Finished graphics/banners uploaded by marketing, for download.
model ContentDeliverable {
  id               String   @id @default(cuid())
  contentRequestId String
  fileName         String
  fileUrl          String
  uploadedAt       DateTime @default(now())

  contentRequest ContentRequest @relation(fields: [contentRequestId], references: [id], onDelete: Cascade)

  @@index([contentRequestId])
}

// ─── Room Bookings ────────────────────────────────────────────────────────────

model RoomBooking {
  id                 String            @id @default(cuid())
  societyId          String
  submittedById      String
  assignedToId       String?
  eventName          String
  preferredDate      DateTime
  startTime          String
  endTime            String
  description        String            @db.Text
  maxAttendees       Int
  hasExternalGuests  Boolean           @default(false)
  externalGuestsDesc String?           @db.Text
  numExternalGuests  Int?
  preferredLocation  PreferredLocation
  safetyOfficerName  String
  safetyOfficerZid   String
  safetyOfficerPhone String
  roomRequirements   String            @db.Text
  status             RoomBookingStatus @default(SUBMITTED)
  submittedToArcAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  society     Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  submittedBy User    @relation("RoomBookingSubmitter", fields: [submittedById], references: [id])
  assignedTo  User?   @relation("RoomBookingAssignee", fields: [assignedToId], references: [id])
  thread      Thread?

  @@index([societyId])
  @@index([status])
}

// ─── Treasury Requests ────────────────────────────────────────────────────────

model TreasuryRequest {
  id               String         @id @default(cuid())
  societyId        String
  submittedById    String
  contactEmail     String
  expenseDate      DateTime
  locationSupplier String
  description      String         @db.Text
  amount           Decimal        @db.Decimal(10, 2)
  bankAccountId    String?
  budgetCategoryId String?
  status           TreasuryStatus @default(DRAFT)
  acknowledgedRules Boolean       @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  society        Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  submittedBy    User                 @relation("TreasurySubmitter", fields: [submittedById], references: [id])
  bankAccount    BankAccount?         @relation(fields: [bankAccountId], references: [id])
  budgetCategory BudgetCategory?      @relation(fields: [budgetCategoryId], references: [id], onDelete: SetNull)
  approvals      TreasuryApproval[]
  receipts       TreasuryAttachment[]
  thread         Thread?

  @@index([societyId])
  @@index([status])
  @@index([budgetCategoryId])
}

model TreasuryApproval {
  id                String   @id @default(cuid())
  treasuryRequestId String
  approvedById      String
  approvedAt        DateTime @default(now())
  isTreasurer       Boolean  @default(false)

  treasuryRequest TreasuryRequest @relation(fields: [treasuryRequestId], references: [id], onDelete: Cascade)
  approvedBy      User            @relation(fields: [approvedById], references: [id])

  @@unique([treasuryRequestId, approvedById])
}

model TreasuryAttachment {
  id                String   @id @default(cuid())
  treasuryRequestId String
  fileName          String
  fileUrl           String
  fileSize          Int
  mimeType          String
  isEventPhoto      Boolean  @default(false)
  uploadedAt        DateTime @default(now())

  treasuryRequest TreasuryRequest @relation(fields: [treasuryRequestId], references: [id], onDelete: Cascade)
}

model PrintingRequest {
  id              String         @id @default(cuid())
  societyId       String
  submittedById   String
  clubName        String
  contactName     String
  contactEmail    String
  contactPhone    String
  pickupAt        DateTime
  quantity        Int
  pages           Int
  paperSize       String         // "A4" | "A3"
  sided           String         // "SINGLE" | "DOUBLE_SHORT" | "DOUBLE_LONG"
  colour          String         // "BW" | "COLOUR"
  fileUrl         String
  fileName        String
  additionalDetails String?      @db.Text
  cost            Decimal        @db.Decimal(10, 2)
  status          PrintingStatus @default(PENDING_APPROVAL)
  decidedById     String?
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  society     Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  submittedBy User    @relation("PrintingSubmitter", fields: [submittedById], references: [id])

  @@index([societyId])
  @@index([status])
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  accountName   String
  bsb           String
  accountNumber String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  treasuryRequests TreasuryRequest[]
}

// ─── Society Titles ───────────────────────────────────────────────────────────

model SocietyTitle {
  id        String   @id @default(cuid())
  societyId String
  name      String
  roleLevel Role
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([societyId, name, roleLevel])
  @@index([societyId])
}

// ─── Thread / Forum ───────────────────────────────────────────────────────────

model Thread {
  id                String  @id @default(cuid())
  contentRequestId  String? @unique
  roomBookingId     String? @unique
  treasuryRequestId String? @unique
  createdAt         DateTime @default(now())

  contentRequest  ContentRequest?  @relation(fields: [contentRequestId], references: [id])
  roomBooking     RoomBooking?     @relation(fields: [roomBookingId], references: [id])
  treasuryRequest TreasuryRequest? @relation(fields: [treasuryRequestId], references: [id])
  comments        Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  threadId   String
  authorId   String
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  thread      Thread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id])
  attachments CommentAttachment[]

  @@index([threadId])
}

model CommentAttachment {
  id        String @id @default(cuid())
  commentId String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  // Delete handlers clean up stale notifications by link.
  @@index([link])
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  societyId String
  title     String
  content   String   @db.Text
  authorId  String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@index([societyId])
}

// ─── Spending Budget ──────────────────────────────────────────────────────────

// A budget line for the society's year-by-year planning + live tracking.
// yearlyBudget is the current (2026) budget; treasury requests classified into
// this category are summed as the live spend and compared against it. The other
// columns are the historical planning figures + rationale, all editable in-app.
model BudgetCategory {
  id           String   @id @default(cuid())
  societyId    String
  name         String
  group        String   @default("PORTFOLIO") // "PORTFOLIO" | "OTHER" — for subtotals
  yearlyBudget Decimal  @default(0) @db.Decimal(10, 2) // the current-year (2026) budget
  budget2024   Decimal? @db.Decimal(10, 2)
  budget2024v2 Decimal? @db.Decimal(10, 2)
  budget2025   Decimal? @db.Decimal(10, 2)
  usage2025    Decimal? @db.Decimal(10, 2)
  worstCase    Decimal? @db.Decimal(10, 2)
  reasoning    String?  @db.Text
  notes        String?  @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  society          Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  treasuryRequests TreasuryRequest[]

  @@unique([societyId, name])
  @@index([societyId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  societyId  String?
  userId     String
  action     AuditAction
  entityType String
  entityId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  society Society? @relation(fields: [societyId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@index([societyId, entityType])
  @@index([userId])
}
