# Database
DATABASE_URL="postgresql://society_user:society_password@localhost:5432/society_platform?schema=public"

# NextAuth
AUTH_SECRET="change-this-to-a-random-secret-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Email (Nodemailer / SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@yoursociety.com"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Society Platform"

# Rubric Integration (hellorubric.com)
# Credentials are configured per-society via the Settings page in the app.
# They are stored in the database (Society.rubricSessionId / rubricSocietyId).
# No env vars needed — configure through Settings > Rubric Integration.

# Single-society deployment (per-domain mode)
# Set this to your society's slug to run a dedicated single-society instance.
# When set, all public URLs are clean (e.g. /dashboard instead of /csesoc/dashboard)
# and access to any other society's data is blocked.
# Leave blank to run in multi-society mode (default).
SOCIETY_SLUG=""
